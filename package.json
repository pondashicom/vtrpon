{
    "name": "VTR-PON2",
    "version": "2.6.2",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder",
        "rebuild:win": "npx @electron/rebuild -f -w winax -i @julusian/freetype2 --arch=x64",
        "dist:win": "npm run rebuild:win && electron-builder --win",
        "deps:mac-arm64": "electron-builder install-app-deps --platform=darwin --arch=arm64",
        "deps:mac-x64": "electron-builder install-app-deps --platform=darwin --arch=x64",
        "dist:mac-arm64": "npm run deps:mac-arm64 && electron-builder --mac --arm64",
        "dist:mac-x64": "npm run deps:mac-x64 && electron-builder --mac --x64",
        "dist": "node -e \"const {execSync}=require('child_process'); const os=process.platform; if(os==='win32'){execSync('npm run dist:win',{stdio:'inherit'})} else if(os==='darwin'){execSync('npm run dist:mac-arm64',{stdio:'inherit'})} else {execSync('electron-builder -l',{stdio:'inherit'})}\"",
        "postinstall": "node -e \"if(process.platform==='win32'){try{require('child_process').execSync('npx @electron/rebuild -f -w winax -i @julusian/freetype2 --arch=x64',{stdio:'inherit'})}catch(e){console.warn('postinstall: rebuild skipped:',e && e.message)}}else{console.log('postinstall: skip on non-Windows')}\""
    },
    "keywords": [],
    "author": "Tetsu Suzuki",
    "license": "GPL-3.0-or-later",
    "description": "VTRPON2",
    "dependencies": {
        "atem-connection": "^3.6.0",
        "ffmpeg-static": "^5.2.0",
        "ffprobe-static": "^3.1.0",
        "fix-webm-duration": "^1.0.6",
        "fluent-ffmpeg": "^2.1.3",
        "node-fetch": "^3.3.2",
        "papaparse": "^5.5.2"
    },
    "optionalDependencies": {
        "winax": "^3.6.1"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.3",
        "electron": "^39.8.6",
        "electron-builder": "^26.8.2"
    },
    "overrides": {
        "tar": "^7.5.13",
        "minimatch": "^10.2.4",
        "ajv": "^6.14.0",
        "picomatch": "^4.0.4",
        "brace-expansion": "^5.0.5",
        "@xmldom/xmldom": "0.8.12",
        "lodash": "^4.18.1"
    },
    "build": {
        "appId": "pondashi.com-vtrpon",
        "win": {
            "icon": "assets/icons/icon.ico"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "icon": "assets/icons/icon_512x512.png"
        },
        "dmg": {
            "sign": true
        },
        "asarUnpack": [
            "**/node_modules/ffmpeg-static/**",
            "**/node_modules/ffprobe-static/**"
        ],
        "extraResources": [
            {
                "from": "assets",
                "to": "assets"
            }
        ],
        "npmRebuild": false
    }
}
